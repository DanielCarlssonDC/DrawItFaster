@{
    ViewData["Title"] = "Profile";
}

<div class="container" style="max-width: 600px;">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger text-center fw-bold mb-4">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success text-center fw-bold">
            <i class="fa-solid fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="element-box offwhite">
        <h2 class="text-center mb-4">My Profile</h2>

        <div class="text-center mb-4">
            <img src="@Model.ProfilePictureUrl" alt="Profile Picture" class="rounded-circle mb-3" style="width: 150px; height: 150px; object-fit: cover; background-color: #333;">
            <h3>@Model.Username</h3>
        </div>

        <hr>

        <form asp-controller="Account" asp-action="UpdatePicture" method="post" class="mb-4 mt-4">
            <div class="mb-3">
                <label class="form-label fw-bold">Change Profile Picture (Image URL)</label>
                <input type="url" name="pictureUrl" class="form-control" placeholder="https://example.com/my-avatar.jpg" value="">
            </div>
            <button type="submit" class="btn-warning w-100 rounded">Update Picture</button>
        </form>

        <hr class="mt-4 mb-4">

        <form asp-controller="Account" asp-action="DeleteUser" method="post" onsubmit="return confirm('Are you sure you want to delete your account?');">
            <button type="submit" class="btn-danger text-white w-100 rounded">Delete Account</button>
        </form>

    </div>
</div>