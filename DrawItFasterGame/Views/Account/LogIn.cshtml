@{
    ViewData["Title"] = "Log in";
}

<div class="login-page-wrapper">

    <form class="login-card element-box" method="post" asp-action="LogIn" asp-controller="Account">
        <h2 class="text-center mb-4">Log in</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger text-center" role="alert">
                @ViewBag.Error
            </div>
        }

        <div class="mb-3">
            <label class="form-label">Username:</label>
            <input class="form-control custom-input" type="text" name="Username" autofocus />
        </div>

        <div class="mb-4">
            <label class="form-label">Password:</label>
            <input class="form-control custom-input" type="password" name="password" />
        </div>

        <button class="btn btn-custom-blue w-100 mb-3" type="submit">Log in</button>

        <div class="text-center">
            <a asp-controller="Account" asp-action="CreateUser" class="register-link">Not a user? Sign up</a>
        </div>
    </form>

</div>