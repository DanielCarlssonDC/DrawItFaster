@using DrawItFaster.DAL
@inject DrawItDbContext _context

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DrawItFasterGame</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DrawItFasterGame.styles.css" asp-append-version="true" />
</head>
<body class="app-layout">
    @{
        var userId = Context.Session.GetInt32("UserId");
        var username = Context.Session.GetString("Username");
        var profilePic = Context.Session.GetString("ProfilePic");
    }
            <header class="position-relative">
                <div class="flex-grow-1">
                    <a class="navbar-brand position-absolute top-50 start-50 translate-middle" asp-area="" asp-controller="Home" asp-action="Index">
                        @if (ViewData["IsGameView"] != null && (bool)ViewData["IsGameView"] == true)
                            {
                                <img src="~/images/Logo.png" alt="DrawItFaster" />
                            } 
                            else {
                                <img src="~/images/LogoFlat.png" alt="DrawItFaster" />
                            }
                    </a>
                </div>

                
                    <div class="headerLoggedIn dropdown ms-auto">
                        <a class="nav-link dropdown-toggle d-flex align-items-center"
                           href="#"
                           role="button"
                           data-bs-toggle="dropdown"
                           aria-expanded="false">

                            <img src="@profilePic" alt="Profile Picture" class="rounded-circle me-2" style="width: 35px; height: 35px; object-fit: cover;">
                            <span>@username</span>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end">
                            <li class="dropdown-item text-muted">Signed in as</li>
                            <li class="dropdown-item fw-bold">@username</li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                    <i class="bi bi-person me-2"></i> View Profile
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">
                                    <i class="bi bi-box-arrow-right me-2"></i>
                                    Log out
                                </a>
                            </li>
                        </ul>
                    </div>
                
            </header>
        
    
  

    <div class="content-wrapper w-100">
        <main role="main" class="w-100">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
