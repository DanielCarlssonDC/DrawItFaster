@model DrawItFasterGame.Services.Game
@{
    ViewData["Title"] = "Game Room";
    var gameId = ViewBag.GameId;
    var myUsername = ViewBag.Username;
}

<div class="container-fluid mt-3" style="max-width: 1200px;">

    <div class="d-flex justify-content-between align-items-center mb-3 text-white px-3">
        <h3 id="roundDisplay" class="m-0 fw-bold">Round @Model.CurrentRound/@Model.MaxRounds</h3>

        <h4 id="wordDisplay" class="m-0 text-center flex-grow-1" style="letter-spacing: 2px;">Waiting for game to start...</h4>

        <div class="bg-white text-dark rounded-circle d-flex justify-content-center align-items-center fw-bold fs-3 shadow" style="width: 60px; height: 60px;">
            <span id="timerDisplay">90</span>
        </div>
    </div>

    <div class="row g-3 h-100">

        <div class="col-md-2">
            <div class="card h-100 p-2 shadow" style="min-height: 500px;">
                <ul id="playersList" class="list-unstyled m-0 d-flex flex-column gap-2">
                    @foreach (var player in Model.Players)
                    {
                        <li class="bg-light rounded p-2 d-flex align-items-center gap-2 border" id="player-@player.Username">
                            <img src="@(string.IsNullOrEmpty(player.ProfilePic) ? "/images/default-avatar.png" : player.ProfilePic)" class="rounded" style="width: 40px; height: 40px; object-fit: cover;">
                            <div class="d-flex flex-column">
                                <span class="fw-bold text-dark" style="font-size: 0.9rem;">@player.Username</span>
                                <span class="text-muted" style="font-size: 0.8rem;">Pts: <span id="score-@player.Username">@player.Score</span></span>
                            </div>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <div class="col-md-7 d-flex flex-column">
            <div class="card p-0 shadow overflow-hidden position-relative" style="flex-grow: 1;">

                <div id="canvasOverlay" class="position-absolute w-100 h-100 d-flex flex-column justify-content-center align-items-center" style="background: rgba(0,0,0,0.7); z-index: 10;">
                    <h2 class="text-white fw-bold mb-4" id="overlayText">Waiting for next turn...</h2>

                    <div id="wordOptions" class="d-none d-flex flex-wrap gap-3 justify-content-center"></div>
                </div>

                <canvas id="drawingCanvas" class="w-100 bg-white" style="cursor: crosshair; height: 500px; display: block;"></canvas>
            </div>

            <div class="card mt-2 p-2 shadow d-flex flex-row align-items-center gap-3">
                <div class="d-flex align-items-center gap-2">
                    <label class="fw-bold text-white m-0">Color:</label>
                    <input type="color" id="colorPicker" value="#000000" class="form-control form-control-color p-1" style="width: 40px; height: 40px;" />
                </div>

                <div class="d-flex align-items-center gap-2 flex-grow-1">
                    <label class="fw-bold text-white m-0">Size:</label>
                    <input type="range" id="brushSize" min="1" max="20" value="2" class="form-range" />
                </div>

                <button id="eraserButton" class="btn btn-light fw-bold">Eraser</button>
                <button id="clearCanvasButton" class="btn btn-danger fw-bold">Clear</button>
            </div>
        </div>

        <div class="col-md-3 d-flex flex-column">
            <div class="card shadow p-2 d-flex flex-column h-100" style="min-height: 500px;">
                <h5 class="text-white fw-bold border-bottom pb-2 border-secondary">Chat & Guesses</h5>

                <ul id="messagesList" class="list-unstyled flex-grow-1 overflow-auto mb-2 text-white" style="max-height: 430px; display: flex; flex-direction: column; justify-content: flex-end;"></ul>

                <div class="d-flex gap-2 mt-auto">
                    <input id="guessInput" class="form-control" placeholder="Type your guess here..." autocomplete="off" />
                    <button id="guessButton" class="btn btn-success fw-bold">Send</button>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script>
        const gameId = "@gameId";
        const myUsername = "@myUsername";

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/gamehub")
            .build();

        const canvas = document.getElementById("drawingCanvas");
        const ctx = canvas.getContext("2d");

        function resizeCanvas() {
            canvas.width = canvas.offsetWidth;
            canvas.height = canvas.offsetHeight;
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        const colorPicker = document.getElementById("colorPicker");
        const brushSize = document.getElementById("brushSize");
        const eraserButton = document.getElementById("eraserButton");
        const clearCanvasButton = document.getElementById("clearCanvasButton");

        const wordOptions = document.getElementById("wordOptions");
        const wordDisplay = document.getElementById("wordDisplay");
        const overlayText = document.getElementById("overlayText");
        const canvasOverlay = document.getElementById("canvasOverlay");
        const guessInput = document.getElementById("guessInput");
        const guessButton = document.getElementById("guessButton");
        const timerDisplay = document.getElementById("timerDisplay");
        const messagesList = document.getElementById("messagesList");

        let currentColor = "#000000";
        let currentSize = 2;
        let isErasing = false;
        let isDrawing = false;
        let isDrawer = false;
        let lastX = 0;
        let lastY = 0;
        let timerInterval;
        let mySelectedWord = ""; // Sparar ordet lokalt för ritaren

        colorPicker.addEventListener("change", () => { currentColor = colorPicker.value; isErasing = false; });
        brushSize.addEventListener("change", () => { currentSize = brushSize.value; });
        eraserButton.addEventListener("click", () => { isErasing = true; });
        clearCanvasButton.addEventListener("click", () => {
            if (!isDrawer) return;
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            connection.invoke("ClearCanvas", gameId);
        });

        canvas.addEventListener("mousedown", (e) => {
            if (!isDrawer) return;
            isDrawing = true;
            lastX = e.offsetX;
            lastY = e.offsetY;
        });

        canvas.addEventListener("mousemove", (e) => {
            if (!isDrawing || !isDrawer) return;
            ctx.beginPath();
            ctx.moveTo(lastX, lastY);
            ctx.lineTo(e.offsetX, e.offsetY);
            ctx.strokeStyle = isErasing ? "#ffffff" : currentColor;
            ctx.lineWidth = currentSize;
            ctx.stroke();

            connection.invoke("SendDrawingData", gameId, {
                startX: lastX, startY: lastY, endX: e.offsetX, endY: e.offsetY,
                color: isErasing ? "#ffffff" : currentColor, size: currentSize
            });

            lastX = e.offsetX;
            lastY = e.offsetY;
        });

        canvas.addEventListener("mouseup", () => { isDrawing = false; });
        canvas.addEventListener("mouseout", () => { isDrawing = false; });

        // Uppdaterad chatt-funktion för rätt färger
        function addChatMessage(user, message, isSystem = false) {
            const li = document.createElement("li");
            li.classList.add("mb-1");

            if (isSystem) {
                li.style.color = "#39ff14"; // Neongrön
                li.classList.add("fw-bold");
                li.innerText = message;
            } else {
                // text-info ger en snygg blå/cyan färg till namnet
                li.innerHTML = `<span class="text-info fw-bold">${user}:</span> <span class="text-white">${message}</span>`;
            }

            messagesList.appendChild(li);
            messagesList.scrollTop = messagesList.scrollHeight;
        }

        function startTimer(seconds) {
            clearInterval(timerInterval);
            let timeLeft = seconds;
            timerDisplay.innerText = timeLeft;

            timerInterval = setInterval(() => {
                timeLeft--;
                timerDisplay.innerText = timeLeft;

                if (timeLeft <= 0) {
                    clearInterval(timerInterval);
                    if (isDrawer) {
                        connection.invoke("NextTurn", gameId);
                    }
                }
            }, 1000);
        }

        connection.on("ReceiveDrawingData", (data) => {
            ctx.beginPath();
            ctx.moveTo(data.startX, data.startY);
            ctx.lineTo(data.endX, data.endY);
            ctx.strokeStyle = data.color;
            ctx.lineWidth = data.size;
            ctx.stroke();
        });

        connection.on("CanvasCleared", () => {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
        });

        connection.on("ReceiveMessage", (user, message) => {
            addChatMessage(user, message, false); // false = vanligt spelarmeddelande
        });

        connection.on("CorrectGuess", (username, score, drawerName, drawerScore) => {
            addChatMessage("", `${username} has guessed the word!`, true); // true = grönt systemmeddelande

            document.getElementById(`score-${username}`).innerText = score;
            document.getElementById(`score-${drawerName}`).innerText = drawerScore;

            if (username === myUsername) {
                guessInput.disabled = true;
                guessButton.disabled = true;
            }
        });

        connection.on("DrawerSelected", (drawerUsername, round) => {
            document.getElementById("roundDisplay").innerText = `Round ${round}/@Model.MaxRounds`;
            clearInterval(timerInterval);
            timerDisplay.innerText = "90";

            document.querySelectorAll("#playersList li").forEach(li => li.classList.remove("border-primary", "border-3"));
            document.getElementById(`player-${drawerUsername}`).classList.add("border-primary", "border-3");

            if (myUsername === drawerUsername) {
                isDrawer = true;
                guessInput.disabled = true;
                guessButton.disabled = true;

                canvasOverlay.classList.remove("d-none");
                overlayText.innerText = "Choose a word to draw!";
                wordDisplay.innerText = "Waiting for you to select a word...";

                fetch("/api/WordAPI/random")
                    .then(response => response.json())
                    .then(words => {
                        wordOptions.innerHTML = "";
                        wordOptions.classList.remove("d-none");

                        words.forEach(word => {
                            const btn = document.createElement("button");
                            btn.className = "btn btn-primary btn-lg fw-bold px-4 shadow"; // Större knappar (btn-lg)
                            btn.textContent = word;
                            btn.onclick = () => {
                                mySelectedWord = word; // Spara ordet lokalt!
                                connection.invoke("SelectWord", gameId, myUsername, word);
                                wordOptions.classList.add("d-none");
                                overlayText.innerText = "Starting round...";
                            };
                            wordOptions.appendChild(btn);
                        });
                    });
            } else {
                isDrawer = false;
                guessInput.disabled = false;
                guessButton.disabled = false;

                wordOptions.classList.add("d-none");
                canvasOverlay.classList.remove("d-none");

                // Endast ett meddelande nu för att undvika dubletter
                overlayText.innerText = `${drawerUsername} is choosing a word...`;
                wordDisplay.innerText = "Waiting for drawer...";
            }
        });

        connection.on("WordSelected", (seconds) => {
            canvasOverlay.classList.add("d-none");
            startTimer(seconds);

            if (isDrawer) {
                addChatMessage("", `You are drawing! The word is hidden for others.`, true);
                // Använder det lokalt sparade ordet!
                wordDisplay.innerText = `Draw the word! (${mySelectedWord})`;
            } else {
                wordDisplay.innerText = "Guess the word!";
                addChatMessage("", `Round started! Guess what is being drawn!`, true);
            }
        });

        connection.on("GameOver", (playersList) => {
            clearInterval(timerInterval);
            canvasOverlay.classList.remove("d-none");
            let winner = playersList[0];
            overlayText.innerHTML = `Game Over!<br>Winner: ${winner.username} with ${winner.score} pts!<br><a href='/' class='btn btn-light mt-3'>Back to Lobby</a>`;
        });

        connection.start().then(() => {
            console.log("Connected to GameHub");
            return connection.invoke("JoinGame", gameId, myUsername);
        }).then(() => {
            const isHost = @((Model.HostId == Context.Session.GetInt32("UserId")).ToString().ToLower());
            if (isHost) {
                setTimeout(() => {
                    connection.invoke("StartGame", gameId);
                }, 1500);
            }
        }).catch(err => console.error(err));

        function sendGuess() {
            const guess = guessInput.value.trim();
            if (guess !== "") {
                connection.invoke("SendGuess", gameId, myUsername, guess);
                guessInput.value = "";
            }
        }

        guessButton.addEventListener("click", sendGuess);
        guessInput.addEventListener("keypress", (e) => {
            if (e.key === "Enter") sendGuess();
        });
    </script>
}